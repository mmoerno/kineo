<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="80dp"
    android:layout_height="100dp"
    android:layout_marginEnd="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_badge_icon"
        android:layout_width="@dimen/badge_icon_size"
        android:layout_height="@dimen/badge_icon_size"
        android:layout_gravity="top|center_horizontal"
        android:padding="4dp"
        android:src="@android:drawable/btn_star"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tv_badge_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:maxLines="2"
        android:text="Badge"
        android:textSize="12sp"
        tools:text="Primer Paso" />

    <View
        android:id="@+id/overlay_locked"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.6"
        android:background="@color/colorBadgeLocked"
        android:visibility="gone" />

</FrameLayout>
